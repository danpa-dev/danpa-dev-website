---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';
import { homeProjectCount, projects } from '../data/projects';

const homeProjects = projects.slice(0, homeProjectCount);
const posts = (await getCollection('writings'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<Layout title="Dan Park" description="Developer, builder, and writer.">
	<div class="container">
		<div class="intro">
			<h1>Dan Park</h1>
			<p>
				Software engineer who likes to understand things deeply. Great conversationalist, decent at trivia, currently down a rabbit hole of AI agents and system design.
			</p>
			<div class="links">
				<a href="https://github.com/danpa-dev" target="_blank" rel="noreferrer">GitHub</a>
				<a href="https://www.linkedin.com/in/dansdansrevolution" target="_blank" rel="noreferrer">LinkedIn</a>
				<a href="mailto:parkdanws@gmail.com">Email</a>
			</div>
		</div>

		<div class="section">
			<h2 class="section-title">
				<a class="section-title-link" href="/projects">Projects</a>
			</h2>
			<div class="card-grid">
				{homeProjects.map((project) => <ProjectCard project={project} showLiveLink={false} />)}
			</div>
		</div>

		<div class="section">
			<h2 class="section-title">
				<a class="section-title-link" href="/writings">Writings</a>
			</h2>
			<div class="post-list">
				{posts.length === 0 ? (
					<p class="home-writings-empty">Nothing here yet—add Markdown under <code>src/content/writings/</code>.</p>
				) : (
					posts.map((post) => (
						<a class="post-item" href={`/writings/${post.slug}`}>
							<span class="post-title">{post.data.title}</span>
								<span class="post-date">{post.data.pubDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric', timeZone: 'UTC' })}</span>
						</a>
					))
				)}
			</div>
		</div>
	</div>
</Layout>
