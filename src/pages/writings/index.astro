---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('writings')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const allTags = [...new Set(posts.flatMap((p) => p.data.tags))].sort((a, b) =>
	a.localeCompare(b)
);
---

<Layout title="Writings — Dan Park" description="Writing about software, process, and projects.">
	<div class="container">
		<Breadcrumbs
			items={[
				{ label: 'Home', href: '/' },
				{ label: 'Writings' },
			]}
		/>
		<div class="section blog-section" id="writings-filter-root">
			<h1 class="section-title">Writings</h1>

			{
				posts.length === 0 ? (
					<p class="writings-empty">
						No writings yet. Add Markdown files to <code>src/content/writings/</code>, then restart the dev server if they do not
						appear.
					</p>
				) : (
					<>
						<div class="blog-toolbar">
							<span class="blog-toolbar-label" id="writings-filter-label">Filter by tag</span>
							<div
								class="tag-filter-chips"
								role="toolbar"
								aria-labelledby="writings-filter-label"
							>
								<button
									type="button"
									class="tag-filter-chip is-active"
									data-tag=""
									aria-pressed="true"
								>
									All
								</button>
								{allTags.map((tag) => (
									<button type="button" class="tag-filter-chip" data-tag={tag} aria-pressed="false">
										{tag}
									</button>
								))}
							</div>
						</div>

						<p class="blog-filter-empty" id="writings-filter-empty" hidden>No posts match this tag.</p>

						<div class="post-list" id="writings-post-list">
							{posts.map((post) => (
								<a
									class="post-item"
									href={`/writings/${post.slug}`}
									data-tags={JSON.stringify(post.data.tags)}
								>
									<div class="post-item-main">
										<span class="post-title">{post.data.title}</span>
										{post.data.tags.length > 0 && (
											<div class="post-item-tags">
												{post.data.tags.map((tag) => (
													<span class="tag">{tag}</span>
												))}
											</div>
										)}
									</div>
									<span class="post-date">
											{post.data.pubDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric', timeZone: 'UTC' })}
									</span>
								</a>
							))}
						</div>
					</>
				)
			}
		</div>
	</div>

	<script>
		import { initWritingsTagFilter } from '../../scripts/writings-tag-filter.ts';

		initWritingsTagFilter();
	</script>
</Layout>
