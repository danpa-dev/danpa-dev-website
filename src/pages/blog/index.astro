---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const allTags = [...new Set(posts.flatMap((p) => p.data.tags))].sort((a, b) =>
	a.localeCompare(b)
);
---

<Layout title="Blog — Dan Park" description="Writing about software, process, and projects.">
	<div class="container">
		<div class="section blog-section" id="blog-filter-root">
			<h1 class="section-title">Blog</h1>

			<div class="blog-toolbar">
				<span class="blog-toolbar-label" id="blog-filter-label">Filter by tag</span>
				<div
					class="tag-filter-chips"
					role="toolbar"
					aria-labelledby="blog-filter-label"
				>
					<button
						type="button"
						class="tag-filter-chip is-active"
						data-tag=""
						aria-pressed="true"
					>
						All
					</button>
					{allTags.map((tag) => (
						<button type="button" class="tag-filter-chip" data-tag={tag} aria-pressed="false">
							{tag}
						</button>
					))}
				</div>
			</div>

			<p class="blog-filter-empty" id="blog-filter-empty" hidden>No posts match this tag.</p>

			<div class="post-list" id="blog-post-list">
				{posts.map((post) => (
					<a
						class="post-item"
						href={`/blog/${post.slug}`}
						data-tags={JSON.stringify(post.data.tags)}
					>
						<div class="post-item-main">
							<span class="post-title">{post.data.title}</span>
							{post.data.tags.length > 0 && (
								<div class="post-item-tags">
									{post.data.tags.map((tag) => (
										<span class="tag">{tag}</span>
									))}
								</div>
							)}
						</div>
						<span class="post-date">
							{post.data.pubDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
						</span>
					</a>
				))}
			</div>
		</div>
	</div>

	<script>
		import { initBlogTagFilter } from '../../scripts/blog-tag-filter.ts';

		initBlogTagFilter();
	</script>
</Layout>
