---
const links = [
	{ href: '/projects', label: 'Projects' },
	{ href: '/writings', label: 'Writings' },
	{ href: '/about', label: 'About' },
];
---

<header class="nav">
	<div class="container nav-inner">
		<a href="/" class="brand">Dan Park</a>
		<nav class="nav-links">
			{links.map((link) => (
				<a href={link.href}>{link.label}</a>
			))}
		</nav>
	</div>
</header>

<style>
	.brand {
		font-weight: 600;
		font-size: 15px;
	}
</style>
