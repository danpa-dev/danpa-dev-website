---
import type { Project } from '../data/projects';

interface Props {
	project: Project;
	/** When false, the whole card is a single link to the writeup (home preview). */
	showLiveLink?: boolean;
}

const { project, showLiveLink = true } = Astro.props;
---

<article class="project-card">
	<a class="project-card-main" href={project.postUrl}>
		<h3>{project.title}</h3>
		<p>{project.description}</p>
		<div class="tags">
			{project.tags.map((tag) => (
				<span class="tag">{tag}</span>
			))}
		</div>
	</a>
	{
		showLiveLink && (
			<div class="card-link-row">
				<a href={project.liveUrl} target="_blank" rel="noreferrer">
					Live site &rarr;
				</a>
			</div>
		)
	}
</article>
