---
interface Props {
	title: string;
	description: string;
	tags: string[];
	postUrl: string;
	liveUrl?: string;
}

const { title, description, tags, postUrl, liveUrl } = Astro.props;
---

<a class="project-item" href={postUrl}>
	<div>
		<span class="project-name">{title}</span>
		<span class="project-desc">{description}</span>
	</div>
	<div class="project-tags">
		{tags.map((tag) => (
			<span class="tag">{tag}</span>
		))}
	</div>
</a>
